@page "/doctors"
@inject HttpClient Http

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3>قائمة الأطباء المعتمدين</h3>
        <a href="add-doctor" class="btn btn-primary">
            <i class="bi bi-plus-lg"></i> إضافة طبيب جديد
        </a>
    </div>

    @if (doctors == null)
    {
        <div class="text-center mt-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">جاري التحميل...</span>
            </div>
            <p class="mt-2">جاري جلب بيانات الأطباء من النظام...</p>
        </div>
    }
    else if (!doctors.Any())
    {
        <div class="alert alert-info text-center">
            لا يوجد أطباء مضافون في النظام حالياً.
        </div>
    }
    else
    {
        <div class="card shadow-sm">
            <div class="card-body">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>الاسم</th>
                            <th>التخصص</th>
                            <th>القسم</th>
                            <th class="text-center">إجراءات</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var doctor in doctors)
                        {
                            <tr>
                                <td class="fw-bold">@doctor.Name</td>
                                <td><span class="badge bg-info text-dark">@doctor.Specialty</span></td>
                                <td>@doctor.DepartmentName</td>
                                <td class="text-center">
                                    <button class="btn btn-sm btn-outline-warning me-2">تعديل</button>
                                    <button class="btn btn-sm btn-outline-danger">حذف</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@code {
    private List<DoctorDto>? doctors;

    protected override async Task OnInitializedAsync()
{
    try 
    {
        // إضافة طباعة في الـ Console لمعرفة أين نقف
        Console.WriteLine("جاري محاولة الاتصال بالـ API...");
        
        doctors = await Http.GetFromJsonAsync<List<DoctorDto>>("api/Doctors");
        
        Console.WriteLine($"تم جلب {doctors?.Count} أطباء بنجاح.");
    }
    catch (Exception ex)
    {
        // هذا السطر سيكتب الخطأ في الـ Console في المتصفح (اضغطي F12 في المتصفح)
        Console.WriteLine($"خطأ كارثي أثناء الاتصال: {ex.Message}");
    }
}

    // كلاس بسيط لنقل البيانات من الـ API إلى الواجهة
    public class DoctorDto
    {
        public int Id { get; set; }
        public string Name { get; set; } = "";
        public string Specialty { get; set; } = "";
        public string DepartmentName { get; set; } = "لا يوجد";
    }
}