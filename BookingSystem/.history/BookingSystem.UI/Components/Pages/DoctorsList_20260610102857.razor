@page "/doctors"
@inject HttpClient Http

<h3>قائمة الأطباء</h3>

@if (doctors == null)
{
    <p><em>جاري تحميل البيانات...</em></p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>الاسم</th>
                <th>التخصص</th>
                <th>الإجراءات</th> </tr>
        </thead>
        <tbody>
            @foreach (var doctor in doctors)
            {
                <tr>
                    <td>@doctor.Name</td>
                    <td>@doctor.Specialty</td>
                    <td>
                        <button class="btn btn-primary" @onclick="() => BookAppointment(doctor.Id)">
                            حجز موعد
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<Doctor>? doctors;

    // دالة التعامل مع ضغط الزر
    private void BookAppointment(int doctorId)
    {
        Console.WriteLine($"تم اختيار الطبيب رقم: {doctorId}");
        // لاحقاً سنضيف هنا عملية الانتقال لصفحة الحجز
    }

    protected override async Task OnInitializedAsync()
    {
        doctors = await Http.GetFromJsonAsync<List<Doctor>>("api/Doctors");
    }

    public class Doctor { public int Id { get; set; } public string Name { get; set; } = ""; public string Specialty { get; set; } = ""; }
}